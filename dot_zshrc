# Git branch/dirty info in the prompt via zsh's built-in vcs_info (no oh-my-zsh).
autoload -Uz vcs_info add-zsh-hook
setopt prompt_subst
zstyle ':vcs_info:git:*' check-for-changes true
zstyle ':vcs_info:git:*' unstagedstr ' %F{red}✗%f'
zstyle ':vcs_info:git:*' stagedstr   ' %F{red}✗%f'
zstyle ':vcs_info:git:*' formats       ' %F{blue}[%b%u%c%F{blue}]%f'
zstyle ':vcs_info:git:*' actionformats ' %F{blue}[%b|%a%u%c%F{blue}]%f'
add-zsh-hook precmd vcs_info

alias ll="ls -l"
export PATH="$HOME/.local/bin:$PATH"
PROMPT='${VIRTUAL_ENV:+%F{magenta}(${VIRTUAL_ENV:t})%f }%F{green}%n@%m%f:%F{blue}%~%f${vcs_info_msg_0_}%# '

# Per-host extras live in ~/.bash_aliases (unmanaged), shared with bash during
# the transition. Sourced last so it can extend or override anything above.
[ -r "$HOME/.bash_aliases" ] && source "$HOME/.bash_aliases"
